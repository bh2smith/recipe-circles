# ---- Database (Postgres; Neon in prod via Vercel Marketplace) ----
DATABASE_URL="postgresql://user:password@localhost:5432/circles_recipe"

# ---- Auth ----
# 32+ byte secret used to sign session JWTs (openssl rand -hex 32)
SESSION_SECRET="dev-only-change-me-please-32bytes-minimum-secret"

# ---- Circles connector (standalone /crc-signin iframe) ----
NEXT_PUBLIC_CONNECTOR_HOST="https://circles.gnosis.io"

# ---- Circles + Gnosis RPC ----
NEXT_PUBLIC_CIRCLES_RPC_URL="https://rpc.aboutcircles.com/"
# Server-side RPC used to verify payment transactions on Gnosis Chain
GNOSIS_RPC_URL="https://rpc.gnosischain.com"

# ---- gCRC group token (wrapped ERC-20) used for unlock payments ----
# Active "Gnosis" group, avatar 0x93ed5a96347927ff6ff6b790f8cf5258240c321f.
# Below is its STATIC/inflationary wrapped ERC-20 ("s-gCRC", 18 decimals) — a plain,
# heavily-used ERC-20 with no demurrage drift, so 1 gCRC == 1e18 for stable pricing.
NEXT_PUBLIC_GCRC_ERC20_ADDRESS="0x78bab8d5ea6b72f8375cc21436857815210f7d02"
